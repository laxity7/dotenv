# The variables specified in this file will override environment variables

#dev, prod or test
FOO_ENV="production"
IS_FOO=true
BAR_DEBUG="false"
ROUND=0.01

# db config
FOO_HOST="localhost"
FOO_NAME="my_base"
FOO_USER="root"
FOO_PASSWORD="123"

# other
EPSILON=0.000000001
FOO="BAR BAZ BAR"
BAZ="BAR BAZ BAR"
BAR=
TEST=
TEST_NULL=NULL
TEST_NULL_1=null
TEST_COMMENT=123
TEST_COMMENT1="123"
TEST_COMMENT2="123"
TEST_COMMENT3="123 #it's no comment"
TEST_COMMENT4="123"
TEST_COMMENT5=true
TEST_COMMENT6="123 foo\"bar"
TEST_COMMENT7="foo bar"

# this is valid too, but strictly not recommended
bar_small=123

# export prefix
export EXPORT_VAR=exported_value

# variable interpolation
INTERP_BASE=hello
INTERP_REF="${INTERP_BASE} world"
INTERP_NUM="port_${FOO_PASSWORD}"
INTERP_NESTED="${INTERP_BASE}_${FOO_ENV}"

# float with leading dot
FLOAT_DOT_PREFIX=.5

# value containing equals sign
EQUALS_VAL="foo=bar=baz"

# long values
LONG_VAL="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua"

# special characters
SPECIAL_CHARS="hello@world.com:8080/path?q=1&r=2"
